# UPPCL SMART proxy — optional env overrides
# ----------------------------------------------------------------------------
# You do NOT need this file to run the proxy. Everything here is optional.
# The only thing actually required is your UPPCL username + password, which
# you supply at login time via POST /auth/login (no env var for those).
#
# Copy to `.env` only if you want to override defaults:
#     cp .env.sample .env && $EDITOR .env
#
# The server auto-loads `.env` via python-dotenv. `.env` is gitignored.
# ----------------------------------------------------------------------------


# ─── Override the upstream constants (rarely needed) ─────────────────────────
# The proxy ships with the current apikey + parent-tenant UUID baked in.
# Override these ONLY if Jio rotates them — you'll see a 401 "API KEY not
# found" or "Invalid TenantId" on login if that ever happens. To refresh,
# open https://uppcl.sem.jio.com/uppclsmart/ in a browser, inspect any
# request in DevTools → Network, and copy the header values here.

# UPPCL_API_KEY=5ab6ef2e-5051-4923-aa65-dc82883af26b
# UPPCL_TENANT=b3ba0ab0-05bc-11f0-bf77-932b3a8bb3cd


# ─── Base URL override (useful for mitmproxy debugging) ──────────────────────
# UPPCL_BASE_URL=https://uppcl.sem.jio.com


# ─── Where to persist the cached JWT + discovered site IDs ───────────────────
# Default: ./uppcl_session.json in the proxy's working directory.
# UPPCL_SESSION_FILE=uppcl_session.json


# ─── Your credentials (NOT read by the server — for your curl/scripts) ──────
# The proxy itself never reads these. They exist only so `source .env` gives
# curl scripts a place to grab them from:
#
#     source .env
#     curl -X POST localhost:8000/auth/login \
#       -H 'content-type: application/json' \
#       -d "{\"username\":\"$UPPCL_USERNAME\",\"password\":\"$UPPCL_PASSWORD\"}"

# UPPCL_USERNAME=your_phone_or_username
# UPPCL_PASSWORD=your_password
